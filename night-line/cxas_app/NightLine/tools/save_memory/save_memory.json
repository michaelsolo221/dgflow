{
  "name": "save_memory",
  "description": "Store a fact about the caller in Firestore. Merges into existing facts without overwriting.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "key": {
        "type": "string",
        "description": "The fact key (e.g. 'favorite_color')"
      },
      "value": {
        "type": "string",
        "description": "The fact value (e.g. 'blue')"
      }
    },
    "required": ["key", "value"]
  }
}
