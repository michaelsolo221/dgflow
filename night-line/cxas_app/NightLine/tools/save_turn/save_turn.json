{
  "name": "save_turn",
  "description": "Append a conversation turn to the caller's memory in Firestore. Caps history at 20 turns.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "role": {
        "type": "string",
        "description": "Who spoke: 'user' or 'model'"
      },
      "text": {
        "type": "string",
        "description": "The text of the turn"
      }
    },
    "required": ["role", "text"]
  }
}
